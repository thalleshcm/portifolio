# Banco de dados (SQLite em dev)
DATABASE_URL="file:./dev.db"
# Para Postgres em produção:
# DATABASE_URL="postgresql://usuario:senha@host:5432/portfolio_db?schema=public"

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="troque-por-uma-string-segura-e-aleatoria-de-pelo-menos-32-chars"

# Credenciais do painel admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="troque-por-senha-forte"

# URL base
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# AWS S3 (descomente para produção)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""

# Cloudinary (descomente para produção)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
